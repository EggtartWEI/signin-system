# Required
AWS_PORTAL_URL=https://your-oa.example.com
RSA_MODULUS_HEX=your_rsa_modulus_hex
RSA_EXPONENT=65537

# Security
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
ALLOWED_ORIGIN_REGEX=
TRUST_PROXY_HEADERS=false
REQUIRE_HTTPS=false
REQUIRE_PORTAL_HTTPS=true
ENABLE_DOCS=false
MAX_BODY_SIZE=10000
RATE_LIMIT_WINDOW_SECONDS=300
RATE_LIMIT_MAX_ATTEMPTS=5
LOCKOUT_SECONDS=1800
RETURN_HTML_CONTENT=false
PORTAL_CONNECT_TIMEOUT=5
PORTAL_READ_TIMEOUT=10

# Whitelist
WHITELIST_ENABLED=false
WHITELIST_DB_PATH=data/whitelist.db
WHITELIST_DEFAULT_IDS=
WHITELIST_DEFAULT_NAMES=
ADMIN_API_TOKEN=change_me
ADMIN_CONTACT_NAME=
ADMIN_CONTACT_PHONE=
ADMIN_CONTACT_EMAIL=

# Logging
LOG_DIR=logs
LOG_LEVEL=INFO
AUDIT_LOG_RETENTION_DAYS=90
APP_LOG_RETENTION_DAYS=30
